# Copy this file to .env and fill in the values.
# Never commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Netlify ───────────────────────────────────────────────────────────────────
# Token: app.netlify.com/user/applications → Personal access tokens
# Site ID: Netlify site → Site configuration → Site ID
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=

# ── Server-side secrets ───────────────────────────────────────────────────────
# These do NOT go here. Set them in the Netlify dashboard:
# Netlify site → Site configuration → Environment variables
#
# SUPABASE_SERVICE_ROLE_KEY   (bypasses RLS — never in frontend)
# RESEND_API_KEY              (if sending email)
# STRIPE_SECRET_KEY           (if taking payments)
# ANTHROPIC_API_KEY           (if using AI features)
