# Local dev only — never commit .env
# Copy this to .env and fill in the values
# After every fresh clone, also create js/env.js manually (it's gitignored)

SUPABASE_URL=
SUPABASE_ANON_KEY=
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=

# Server-side secrets — set these in Netlify dashboard, NOT here
# netlify env:set SUPABASE_SERVICE_ROLE_KEY your-key
# netlify env:set RESEND_API_KEY your-key
# netlify env:set ANTHROPIC_API_KEY your-key
# netlify env:set XENDIT_SECRET_KEY your-key (PH billing)
# netlify env:set STRIPE_SECRET_KEY your-key (international billing)
