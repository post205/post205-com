# Copy this file to .env and fill in the values.
# Never commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Shared project across all publications for this client.
# Public site reads only — anon key is safe client-side with RLS.
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Netlify ───────────────────────────────────────────────────────────────────
# Token: app.netlify.com/user/applications → Personal access tokens
# Site ID: Netlify site → Site configuration → Site ID
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
