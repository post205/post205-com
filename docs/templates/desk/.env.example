# Copy this file to .env and fill in the values.
# Never commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Same project as the paired website — do not create a new Supabase project for desk.
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Netlify ───────────────────────────────────────────────────────────────────
# Token: app.netlify.com/user/applications → Personal access tokens
# Site ID: Netlify site → Site configuration → Site ID
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=

# ── Server-side secrets ───────────────────────────────────────────────────────
# These do NOT go here. Set them in the Netlify dashboard:
# Netlify site → Site configuration → Environment variables
#
# SUPABASE_SERVICE_ROLE_KEY   (needed for admin user management — never in frontend)
# RESEND_API_KEY              (if sending email notifications)
